{
  "name": "FLLMember",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do membro"
    },
    "photo_url": {
      "type": "string",
      "description": "URL da foto"
    },
    "role": {
      "type": "string",
      "description": "Fun\u00e7\u00e3o na equipe"
    },
    "skills": {
      "type": "string",
      "description": "Habilidades"
    },
    "contributions": {
      "type": "string",
      "description": "Contribui\u00e7\u00f5es principais"
    },
    "order": {
      "type": "number",
      "default": 0,
      "description": "Ordem de exibi\u00e7\u00e3o"
    }
  },
  "required": [
    "name",
    "role"
  ]
}